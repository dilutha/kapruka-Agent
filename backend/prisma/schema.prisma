generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Authenticated users — identity managed by Clerk
/// Created on first sign-in via Clerk webhook
model User {
  id                String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clerkId           String           @unique @map("clerk_id")
  email             String           @unique
  name              String?
  phone             String?
  preferredLanguage Language         @default(EN) @map("preferred_language")
  role              UserRole         @default(CUSTOMER)
  avatarUrl         String?          @map("avatar_url")
  isActive          Boolean          @default(true) @map("is_active")
  /// Soft-delete timestamp — user data retained for compliance
  deletedAt         DateTime?        @map("deleted_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  analyticsEvents   AnalyticsEvent[]
  auditLogs         AuditLog[]
  carts             Cart[]
  chats             Chat[]
  orders            Order[]
  recommendations   Recommendation[]
  savedAddresses    SavedAddress[]
  sessions          Session[]

  @@index([clerkId])
  @@index([email])
  @@index([isActive])
  @@map("users")
}

/// Anonymous shoppers — no Clerk account required
/// Session token is HMAC-signed (see GuestTokenService)
/// Automatically expires after 72 hours
model GuestUser {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sessionToken      String    @unique @map("session_token")
  email             String?
  name              String?
  phone             String?
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  /// ISO country code detected from IP (for regional pricing)
  countryCode       String?   @map("country_code") @db.Char(2)
  createdAt         DateTime  @default(now()) @map("created_at")
  expiresAt         DateTime  @map("expires_at")
  /// Set when guest upgrades to full account
  convertedAt       DateTime? @map("converted_at")
  convertedToUserId String?   @map("converted_to_user_id") @db.Uuid
  carts             Cart[]
  chats             Chat[]
  orders            Order[]
  sessions          Session[]

  @@index([sessionToken])
  @@index([expiresAt])
  @@map("guest_users")
}

/// HTTP sessions — tracks active browser sessions for both user types
/// Separate from Clerk sessions — used for guest token + rate limiting
model Session {
  id                String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId            String?    @map("user_id") @db.Uuid
  guestUserId       String?    @map("guest_user_id") @db.Uuid
  token             String     @unique
  ipAddress         String?    @map("ip_address")
  userAgent         String?    @map("user_agent")
  isValid           Boolean    @default(true) @map("is_valid")
  createdAt         DateTime   @default(now()) @map("created_at")
  expiresAt         DateTime   @map("expires_at")
  lastSeenAt        DateTime   @default(now()) @map("last_seen_at")
  /// Invalidation reason for audit trail
  invalidatedReason String?    @map("invalidated_reason")
  guestUser         GuestUser? @relation(fields: [guestUserId], references: [id], onDelete: Cascade)
  user              User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([guestUserId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Saved delivery addresses for authenticated users
/// Allows faster re-ordering to the same address
model SavedAddress {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  label         String?
  recipientName String   @map("recipient_name")
  phone         String
  addressLine1  String   @map("address_line1")
  addressLine2  String?  @map("address_line2")
  city          String
  district      String
  postalCode    String?  @map("postal_code")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_addresses")
}

/// A single conversation thread between a user (or guest) and the AI agent
/// Persists the LangGraph state so conversations can be resumed across sessions
model Chat {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId           String?          @map("user_id") @db.Uuid
  guestUserId      String?          @map("guest_user_id") @db.Uuid
  /// Auto-generated from first user message (truncated to 80 chars)
  title            String?
  status           ChatStatus       @default(ACTIVE)
  detectedLanguage Language         @default(EN) @map("detected_language")
  /// Serialised LangGraph AgentState — restored on each turn
  /// Enables cart continuity, language memory, and context recall
  contextState     Json?            @map("context_state")
  /// Rolling summary of past turns (prevents context overflow)
  /// Updated every 10 messages by a background summarisation job
  memoryContext    String?          @map("memory_context")
  /// Total messages exchanged — used to trigger summarisation
  messageCount     Int              @default(0) @map("message_count")
  /// Last message preview shown in sidebar
  lastMessageAt    DateTime?        @map("last_message_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  guestUser        GuestUser?       @relation(fields: [guestUserId], references: [id], onDelete: Cascade)
  user             User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages         Message[]
  recommendations  Recommendation[]

  @@index([userId, lastMessageAt(sort: Desc)])
  @@index([guestUserId, lastMessageAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([status])
  @@map("chats")
}

/// Individual turn in a conversation
/// Stores both user inputs and AI responses, including all tool calls
model Message {
  id         String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  chatId     String      @map("chat_id") @db.Uuid
  role       MessageRole
  /// Full message text — may be empty for pure tool-call messages
  content    String
  /// OpenAI-format tool_calls array (for ASSISTANT messages that invoked tools)
  /// [{ id, type, function: { name, arguments } }]
  toolCalls  Json?       @map("tool_calls")
  /// Tool execution result (for TOOL role messages)
  /// { toolName, result, durationMs }
  toolResult Json?       @map("tool_result")
  /// Runtime metadata: model used, token counts, latency, detected language
  /// { model, promptTokens, completionTokens, totalTokens, latencyMs, language }
  metadata   Json?
  /// True when our prompt injection guard flagged this message
  /// The message is still stored for audit but never forwarded to the LLM
  isFlagged  Boolean     @default(false) @map("is_flagged")
  /// Optional: which Kapruka products were surfaced in this message
  productIds String[]    @default([]) @map("product_ids")
  createdAt  DateTime    @default(now()) @map("created_at")
  chat       Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@index([isFlagged])
  @@map("messages")
}

/// Short-lived local cache of Kapruka catalog data
/// Avoids hitting the MCP API on every search — TTL 30 min
/// Refreshed lazily on cache miss; force-refreshed by a nightly job
model ProductCache {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// Kapruka's own product identifier
  kaprukaProdId String   @unique @map("kapruka_prod_id")
  name          String
  nameEn        String?  @map("name_en")
  nameSi        String?  @map("name_si")
  category      String
  subcategory   String?
  /// LKR amounts — always Decimal, never Float
  priceMin      Decimal  @map("price_min") @db.Decimal(10, 2)
  priceMax      Decimal  @map("price_max") @db.Decimal(10, 2)
  currency      String   @default("LKR")
  isAvailable   Boolean  @default(true) @map("is_available")
  imageUrls     String[] @default([]) @map("image_urls")
  tags          String[] @default([])
  /// Full raw response from Kapruka MCP — never modify, preserves future fields
  rawData       Json     @map("raw_data")
  fetchedAt     DateTime @default(now()) @map("fetched_at")
  expiresAt     DateTime @map("expires_at")

  @@index([name(ops: raw("gin_trgm_ops"))], map: "product_cache_name_trgm", type: Gin)
  @@index([category])
  @@index([isAvailable, category])
  @@index([expiresAt])
  @@map("products_cache")
}

/// AI-generated product recommendation sets
/// Each recommendation is tied to a chat session
/// Feedback field enables offline model quality measurement
model Recommendation {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  chatId     String   @map("chat_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  /// Ordered list of recommended Kapruka product IDs
  productIds String[] @map("product_ids")
  /// Which agent node generated this (search / gift / recommend)
  sourceNode String?  @map("source_node")
  /// Plain-English reasoning stored for explainability logging
  reasoning  String?
  /// User's implicit feedback signal
  /// "clicked" | "added_to_cart" | "purchased" | "ignored"
  feedback   String?
  createdAt  DateTime @default(now()) @map("created_at")
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([chatId])
  @@index([userId])
  @@map("recommendations")
}

/// Shopping cart — one ACTIVE cart per user/guest at a time
/// Becomes CHECKED_OUT when converted to an Order
model Cart {
  id             String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String?    @map("user_id") @db.Uuid
  guestUserId    String?    @map("guest_user_id") @db.Uuid
  status         CartStatus @default(ACTIVE)
  /// Running total — denormalised for fast UI display
  /// Recalculated on every item change
  totalAmount    Decimal    @default(0) @map("total_amount") @db.Decimal(10, 2)
  currency       String     @default("LKR")
  itemCount      Int        @default(0) @map("item_count")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  /// When the cart last had an item added — used for abandonment detection
  lastActivityAt DateTime?  @map("last_activity_at")
  items          CartItem[]
  guestUser      GuestUser? @relation(fields: [guestUserId], references: [id], onDelete: Cascade)
  user           User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([guestUserId, status])
  @@index([status, lastActivityAt])
  @@map("carts")
}

/// Line item within a cart
/// productSnapshot captures the product data at the moment it was added
/// — prevents price/availability changes from silently altering the cart
model CartItem {
  id              String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cartId          String       @map("cart_id") @db.Uuid
  kaprukaProdId   String       @map("kapruka_prod_id")
  productName     String       @map("product_name")
  unitPrice       Decimal      @map("unit_price") @db.Decimal(10, 2)
  quantity        Int          @default(1)
  currency        String       @default("LKR")
  /// Full Kapruka product JSON captured at add-to-cart time
  /// Never mutated — source of truth for checkout pricing
  productSnapshot Json         @map("product_snapshot")
  /// Optional per-item gift message (one item can be a gift)
  giftMessageId   String?      @map("gift_message_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  cart            Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  giftMessage     GiftMessage? @relation(fields: [giftMessageId], references: [id])

  @@index([cartId])
  @@index([kaprukaProdId])
  @@map("cart_items")
}

/// Confirmed purchase — created when a cart is checked out
/// kaprukOrderId links back to Kapruka's own order management system
model Order {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String?         @map("user_id") @db.Uuid
  guestUserId     String?         @map("guest_user_id") @db.Uuid
  /// Kapruka platform order reference (e.g. "KP44821")
  /// Null until Kapruka MCP confirms the order
  kaprukOrderId   String?         @unique @map("kapruka_order_id")
  status          OrderStatus     @default(PENDING)
  subtotal        Decimal         @db.Decimal(10, 2)
  deliveryFee     Decimal         @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  discount        Decimal         @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal         @map("total_amount") @db.Decimal(10, 2)
  currency        String          @default("LKR")
  /// Full delivery address snapshot at order time
  shippingAddress Json            @map("shipping_address")
  /// Customer notes / special instructions
  notes           String?
  /// Promo or discount code applied
  couponCode      String?         @map("coupon_code")
  /// Source channel: "chat" | "checkout_page" | "reorder"
  source          String          @default("chat")
  placedAt        DateTime        @default(now()) @map("placed_at")
  confirmedAt     DateTime?       @map("confirmed_at")
  cancelledAt     DateTime?       @map("cancelled_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  delivery        Delivery?
  giftMessages    GiftMessage[]
  orderItems      OrderItem[]
  guestUser       GuestUser?      @relation(fields: [guestUserId], references: [id])
  user            User?           @relation(fields: [userId], references: [id])
  payment         Payment?
  trackingEvents  TrackingEvent[]

  @@index([userId, placedAt(sort: Desc)])
  @@index([guestUserId, placedAt(sort: Desc)])
  @@index([kaprukOrderId])
  @@index([status])
  @@index([placedAt(sort: Desc)])
  @@map("orders")
}

/// Snapshot of what was ordered — immutable once created
/// Cart items are copied here at checkout so the order is self-contained
model OrderItem {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId         String   @map("order_id") @db.Uuid
  kaprukaProdId   String   @map("kapruka_prod_id")
  productName     String   @map("product_name")
  unitPrice       Decimal  @map("unit_price") @db.Decimal(10, 2)
  quantity        Int
  currency        String   @default("LKR")
  /// Full product snapshot — independent of ProductCache expiry
  productSnapshot Json     @map("product_snapshot")
  createdAt       DateTime @default(now()) @map("created_at")
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

/// Payment record for an order
/// IMPORTANT: raw card data is NEVER stored here
/// paymentToken holds the provider's tokenized reference only
model Payment {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId         String        @unique @map("order_id") @db.Uuid
  /// "stripe" | "payhere" | "cod"
  provider        String
  /// Provider's transaction / charge reference
  providerRef     String?       @unique @map("provider_ref")
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("LKR")
  /// Tokenized card reference — NOT a raw card number
  paymentToken    String?       @map("payment_token")
  /// Raw provider webhook payload — preserved for reconciliation
  providerPayload Json?         @map("provider_payload")
  /// General metadata: last4, brand, country, etc.
  metadata        Json?
  failureReason   String?       @map("failure_reason")
  processedAt     DateTime?     @map("processed_at")
  refundedAt      DateTime?     @map("refunded_at")
  refundAmount    Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([provider, status])
  @@map("payments")
}

/// Delivery record — one per order
/// Tracks the full physical journey from warehouse to recipient
model Delivery {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId           String             @unique @map("order_id") @db.Uuid
  recipientName     String             @map("recipient_name")
  recipientPhone    String             @map("recipient_phone")
  /// Full address snapshot — denormalised from Order.shippingAddress
  address           Json
  status            DeliveryStatus     @default(SCHEDULED)
  /// Courier / logistics provider name
  courierName       String?            @map("courier_name")
  /// Courier's own tracking reference
  courierRef        String?            @map("courier_ref")
  scheduledAt       DateTime?          @map("scheduled_at")
  pickedUpAt        DateTime?          @map("picked_up_at")
  deliveredAt       DateTime?          @map("delivered_at")
  /// GPS coordinates at delivery confirmation (if provided)
  deliveryLat       Decimal?           @map("delivery_lat") @db.Decimal(10, 7)
  deliveryLng       Decimal?           @map("delivery_lng") @db.Decimal(10, 7)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliverySchedules DeliverySchedule[]

  @@index([status])
  @@index([scheduledAt])
  @@map("deliveries")
}

/// Available delivery time slots fetched from the Kapruka MCP API
/// Cached locally to show users without another API call
model DeliverySchedule {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  deliveryId      String   @map("delivery_id") @db.Uuid
  /// Kapruka's slot identifier
  slotId          String   @map("slot_id")
  slotDate        DateTime @map("slot_date")
  /// Human-readable label shown in UI: "Morning (9am–12pm)"
  slotLabel       String   @map("slot_label")
  isConfirmed     Boolean  @default(false) @map("is_confirmed")
  /// Kapruka confirmed slot ID after order placement
  confirmedSlotId String?  @map("confirmed_slot_id")
  createdAt       DateTime @default(now()) @map("created_at")
  delivery        Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@index([slotDate])
  @@map("delivery_schedules")
}

/// Personal message card attached to an order or individual cart item
/// isAnonymous = true hides the fromName on the printed card
model GiftMessage {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId     String     @map("order_id") @db.Uuid
  fromName    String     @map("from_name")
  toName      String     @map("to_name")
  /// Free-text message — max 150 chars enforced at application layer
  message     String
  isAnonymous Boolean    @default(false) @map("is_anonymous")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  cartItems   CartItem[]
  order       Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("gift_messages")
}

/// Immutable timeline of events for an order
/// Populated from Kapruka MCP webhooks + polling
model TrackingEvent {
  id          String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  orderId     String            @map("order_id") @db.Uuid
  eventType   TrackingEventType @map("event_type")
  /// Human-readable description shown in the tracking timeline
  description String
  /// Warehouse / city where event occurred
  location    String?
  /// Raw Kapruka webhook payload
  metadata    Json?
  occurredAt  DateTime          @default(now()) @map("occurred_at")
  order       Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, occurredAt(sort: Desc)])
  @@index([eventType])
  @@map("tracking_events")
}

/// High-volume event log for PostHog enrichment and internal analytics
/// Schema is intentionally schema-less (properties: JsonB) to allow
/// new event types without migrations
model AnalyticsEvent {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  sessionId  String?  @map("session_id")
  guestId    String?  @map("guest_id")
  /// Event name — maps to AnalyticsEventName union type in analytics.service.ts
  eventName  String   @map("event_name")
  /// Arbitrary event properties — vary by eventName
  properties Json?
  language   Language @default(EN)
  /// Source: "web" | "mobile" | "api"
  platform   String   @default("web")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id])

  @@index([eventName, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([sessionId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("analytics_events")
}

/// Append-only audit trail for all mutations on sensitive tables
/// Written by application code (not DB triggers) so it captures
/// the business context (who, why) alongside the data change
///
/// Tables audited: users, orders, payments, deliveries, gift_messages
model AuditLog {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  /// Which table was mutated
  tableName   String      @map("table_name")
  /// PK of the mutated row
  recordId    String      @map("record_id")
  action      AuditAction
  /// The authenticated user who triggered the change (null = system / cron)
  actorUserId String?     @map("actor_user_id") @db.Uuid
  /// Full row state BEFORE the change (null for INSERT)
  oldValues   Json?       @map("old_values")
  /// Full row state AFTER the change (null for DELETE)
  newValues   Json?       @map("new_values")
  /// Human-readable description of why the change was made
  reason      String?
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  createdAt   DateTime    @default(now()) @map("created_at")
  actor       User?       @relation(fields: [actorUserId], references: [id])

  @@index([tableName, recordId])
  @@index([actorUserId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

/// Supported UI and agent languages
enum Language {
  EN
  SI
  SINGLISH
}

/// User account roles
enum UserRole {
  GUEST
  CUSTOMER
  ADMIN
}

/// Chat session lifecycle
enum ChatStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

/// Role of each message in a chat thread
enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

/// Shopping cart lifecycle
enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
  EXPIRED
}

/// Order fulfillment lifecycle
enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

/// Payment transaction lifecycle
enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  VOIDED
}

/// Delivery fulfillment lifecycle
enum DeliveryStatus {
  SCHEDULED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RESCHEDULED
}

/// Granular tracking event types (maps to Kapruka tracking API)
enum TrackingEventType {
  ORDER_PLACED
  ORDER_CONFIRMED
  PAYMENT_CAPTURED
  WAREHOUSE_PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  DELIVERY_ATTEMPTED
  DELIVERY_FAILED
  RETURNED
  REFUNDED
}

/// Database audit log operation types
enum AuditAction {
  INSERT
  UPDATE
  DELETE
}
